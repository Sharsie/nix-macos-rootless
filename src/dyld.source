SCRIPT_DIR=$(dirname "$(realpath $0)")

LIBPATHS=$(find "$SCRIPT_DIR/store" -type f -name "*.dylib" -exec dirname {} \; | sort -u)
SORTED_LIBPATHS=$(grep -v "libiconv-1.18/" <<< "$LIBPATHS")
ORDERED_LIBPATHS=$(grep "libiconv-1.18/" <<< "$LIBPATHS")
DYLD_FALLBACK_LIBRARY_PATH=""
while IFS= read -r dir; do DYLD_FALLBACK_LIBRARY_PATH="$DYLD_FALLBACK_LIBRARY_PATH:$dir"; done <<< "$SORTED_LIBPATHS"
while IFS= read -r dir; do DYLD_FALLBACK_LIBRARY_PATH="$DYLD_FALLBACK_LIBRARY_PATH:$dir"; done <<< "$ORDERED_LIBPATHS"
export DYLD_FALLBACK_LIBRARY_PATH="${DYLD_FALLBACK_LIBRARY_PATH:1}"
